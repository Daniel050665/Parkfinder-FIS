<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.parkfinder.controller.MisReservasController"
      prefWidth="1000" prefHeight="640"
      style="-fx-background-color: white;">

    <!-- Barra de navegación -->
    <HBox prefHeight="48" alignment="CENTER_LEFT"
          style="-fx-background-color: #1B4332; -fx-padding: 0 24 0 24; -fx-spacing: 0;">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Rectangle width="26" height="26" arcWidth="6" arcHeight="6" fill="#52B788"/>
            <Label text="ParkFinder"
                   style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
        </HBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="24" alignment="CENTER">
            <Label text="Inicio" style="-fx-text-fill: #9FE1CB; -fx-font-size: 13px; -fx-cursor: hand;" onMouseClicked="#irAInicio"/>
            <Label text="Mis reservas"
                   style="-fx-text-fill: white; -fx-font-size: 13px; -fx-border-color: #52B788; -fx-border-width: 0 0 2 0; -fx-padding: 0 0 2 0;"/>
            <Label text="Historial" style="-fx-text-fill: #9FE1CB; -fx-font-size: 13px; -fx-cursor: hand;"/>
            <Label text="Suscripción" style="-fx-text-fill: #9FE1CB; -fx-font-size: 13px; -fx-cursor: hand;" onMouseClicked="#irASuscripcion"/>
        </HBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <StackPane>
                <Circle radius="15" fill="#52B788"/>
                <Label fx:id="inicialesLabel" text="JP"
                       style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </StackPane>
            <Label fx:id="nombreUsuarioLabel" text="Juan Pérez"
                   style="-fx-text-fill: white; -fx-font-size: 13px;"/>
        </HBox>
    </HBox>

    <!-- Contenido principal -->
    <HBox VBox.vgrow="ALWAYS">

        <!-- Panel principal: reservas -->
        <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 28 32 28 32; -fx-spacing: 0;">
            <Label text="Mis reservas"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
            <Label text="Gestiona tus reservas activas y pasadas"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 13px; -fx-padding: 4 0 24 0;"/>

            <!-- Reserva activa -->
            <Label text="Reserva activa"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151; -fx-padding: 0 0 12 0;"/>

            <VBox style="-fx-border-color: #1B4332; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-background-color: white; -fx-padding: 20; -fx-spacing: 16; -fx-padding: 0 0 24 0;">
                <HBox alignment="CENTER_LEFT">
                    <VBox HBox.hgrow="ALWAYS">
                        <Label fx:id="nombreReservaActivaLabel" text="Parqueadero Central · Cupo A-02"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <Label fx:id="direccionReservaActivaLabel" text="Cra 13 # 52-40, Chapinero"
                               style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
                    </VBox>
                    <Label text="Activa"
                           style="-fx-text-fill: #27500A; -fx-background-color: #EAF3DE; -fx-background-radius: 20; -fx-padding: 4 12 4 12; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                </HBox>

                <GridPane hgap="16" vgap="0"
                          style="-fx-background-color: #f9fafb; -fx-background-radius: 6; -fx-padding: 14;">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="33"/>
                        <ColumnConstraints percentWidth="33"/>
                        <ColumnConstraints percentWidth="34"/>
                    </columnConstraints>
                    <VBox GridPane.columnIndex="0">
                        <Label text="Inicio" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
                        <Label fx:id="inicioReservaLabel" text="26/03/2026 9:00 AM"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    </VBox>
                    <VBox GridPane.columnIndex="1">
                        <Label text="Fin estimado" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
                        <Label fx:id="finReservaLabel" text="26/03/2026 11:00 AM"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    </VBox>
                    <VBox GridPane.columnIndex="2">
                        <Label text="Vehículo" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
                        <Label fx:id="vehiculoReservaLabel" text="ABC-123"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    </VBox>
                </GridPane>

                <HBox spacing="10">
                    <Button text="Cancelar reserva"
                            onAction="#handleCancelarReserva"
                            style="-fx-background-color: transparent; -fx-border-color: #E24B4A; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: #A32D2D; -fx-font-size: 13px; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                    <Button text="Modificar horario"
                            onAction="#handleModificarReserva"
                            style="-fx-background-color: transparent; -fx-border-color: #d1d5db; -fx-border-width: 1; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: #374151; -fx-font-size: 13px; -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- Historial -->
            <Label text="Reservas anteriores"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151; -fx-padding: 24 0 12 0;"/>

            <TableView fx:id="tablaHistorial" VBox.vgrow="ALWAYS"
                       style="-fx-font-size: 13px;">
                <columns>
                    <TableColumn fx:id="colParqueadero" text="Parqueadero" prefWidth="220"/>
                    <TableColumn fx:id="colFecha" text="Fecha" prefWidth="120"/>
                    <TableColumn fx:id="colDuracion" text="Duración" prefWidth="100"/>
                    <TableColumn fx:id="colTotal" text="Total" prefWidth="100"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="150"/>
                </columns>
                <placeholder>
                    <Label text="Sin reservas anteriores"/>
                </placeholder>
            </TableView>
        </VBox>

        <!-- Panel lateral derecho -->
        <VBox prefWidth="280"
              style="-fx-background-color: #fafafa; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 0 1; -fx-padding: 24 20 24 20; -fx-spacing: 16;">

            <Label text="Mi cuenta"
                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

            <!-- Suscripción -->
            <VBox style="-fx-background-color: #1B4332; -fx-background-radius: 8; -fx-padding: 16; -fx-spacing: 4;">
                <Label text="SUSCRIPCIÓN"
                       style="-fx-text-fill: #9FE1CB; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <Label fx:id="planLabel" text="Plan Mensual Activo"
                       style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label fx:id="vencimientoLabel" text="Vence: 30/04/2026"
                       style="-fx-text-fill: #9FE1CB; -fx-font-size: 12px;"/>
                <Button text="Gestionar suscripción"
                        onAction="#handleGestionarSuscripcion"
                        maxWidth="Infinity"
                        style="-fx-background-color: #52B788; -fx-text-fill: white; -fx-background-radius: 4; -fx-border-radius: 4; -fx-font-size: 12px; -fx-padding: 6 0 6 0; -fx-cursor: hand; -fx-padding: 12 0 0 0;"/>
            </VBox>

            <!-- Fidelización -->
            <VBox style="-fx-background-color: #FAEEDA; -fx-border-color: #FAC775; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 16; -fx-spacing: 8;">
                <Label text="FIDELIZACIÓN"
                       style="-fx-text-fill: #633806; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                <Label text="Usos pagados este mes"
                       style="-fx-text-fill: #412402; -fx-font-size: 13px;"/>
                <HBox spacing="8">
                    <StackPane>
                        <Circle radius="16" fill="#EF9F27"/>
                        <Label text="✓" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </StackPane>
                    <StackPane>
                        <Circle radius="16" fill="#EF9F27"/>
                        <Label text="✓" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </StackPane>
                    <StackPane>
                        <Circle radius="16" fill="#FAC775" style="-fx-stroke: #EF9F27; -fx-stroke-width: 2;"/>
                        <Label text="3" style="-fx-text-fill: #633806; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </StackPane>
                </HBox>
                <Label fx:id="fidelizacionLabel" text="1 uso más = reserva gratis"
                       style="-fx-text-fill: #633806; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Vehículo -->
            <VBox style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 16; -fx-spacing: 8;">
                <Label text="Mi vehículo"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <Label fx:id="placaLabel" text="ABC-123"
                       style="-fx-font-size: 13px; -fx-text-fill: #374151;"/>
                <Label fx:id="tipoVehiculoLabel" text="Toyota Corolla · Automóvil"
                       style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
                <Label text="+ Agregar vehículo"
                       onMouseClicked="#handleAgregarVehiculo"
                       style="-fx-text-fill: #1B4332; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 8 0 0 0;"/>
            </VBox>
        </VBox>
    </HBox>
</VBox>
